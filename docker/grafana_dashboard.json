          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-inference" }
        },
        {
          "expr": "inference_requests_inflight",
          "legendFormat": "in-flight",
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-inference" }
        }
      ]
    },
    {
      "type": "timeseries",
